{
  "name": "talkback",
  "version": "0.1.0",
  "private": true,
  "description": "Reactive laptop personality app",
  "author": "David Ifebueme",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "dev": "npm run build && electron .",
    "lint": "tsc -p tsconfig.json --noEmit",
    "package": "npm run build && electron-builder --publish never",
    "package:linux": "npm run build && electron-builder --linux AppImage --publish never",
    "package:mac": "npm run build && electron-builder --mac dmg --publish never",
    "package:win": "npm run build && electron-builder --win nsis --publish never",
    "postinstall": "electron-builder install-app-deps",
    "test": "vitest run",
    "test:watch": "vitest",
    "rebuild:native": "electron-rebuild -f -w uiohook-napi"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "systeminformation": "^5.31.5",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "electron": "^41.1.1",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "build": {
    "appId": "com.talkback.app",
    "productName": "TalkBack",
    "asar": true,
    "files": [
      "dist/**/*",
      "src/renderer/index.html",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "directories": {
      "output": "release"
    }
  }
}
